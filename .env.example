# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/tracker?appName=Cluster0

# Public base URL of this backend (used to construct short URLs)
BASE_URL=https://your-backend.railway.app

# Server port (Railway sets this automatically)
PORT=3000

# Comma-separated list of allowed frontend origins for CORS
# e.g. https://your-dashboard.vercel.app
ALLOWED_ORIGINS=http://localhost:3001
